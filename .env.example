# ============================================
# MIKROTIK NAC SYSTEM - ENVIRONMENT VARIABLES
# ============================================

# Copy this file to .env and update with your values

# ============ ROUTER CONFIGURATION ============
ROUTER_IP=192.168.88.1
ROUTER_PORT=8728
ROUTER_USER=admin
ROUTER_PASSWORD=
ROUTER_VERIFY_SSL=False
ROUTER_TIMEOUT=10

# ============ APPLICATION ============
APP_NAME="MikroTik NAC System"
APP_VERSION="1.0.0"
DEBUG=False
LOG_LEVEL=INFO

# ============ SERVER ============
APP_HOST=0.0.0.0
APP_PORT=8080

# ============ AUTHENTICATION ============
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ============ DATABASE ============
DATABASE_URL=sqlite:///data/db.sqlite3

# ============ SCHEDULER ============
TRAFFIC_SYNC_INTERVAL=300
EXPIRY_CHECK_INTERVAL=600
HEALTH_CHECK_INTERVAL=60
DEVICE_SYNC_INTERVAL=30
ISP_SYNC_INTERVAL=30
ROUTE_SYNC_INTERVAL=60

# ============ DHCP ============
DHCP_POOL_START=192.168.88.100
DHCP_POOL_END=192.168.88.200
GATEWAY_IP=192.168.88.1
DNS_SERVERS=8.8.8.8,8.8.4.4

# ============ WIFI ============
WIFI_SSID=NAC-Network
WIFI_INTERFACE=wlan1

# ============ QOS PROFILES ============
PROFILE_ADMIN_LIMIT=0/0
PROFILE_PROFESIONAL_LIMIT=10M/5M
PROFILE_ESTANDAR_LIMIT=5M/2M
PROFILE_INVITADO_LIMIT=2M/1M

# ============ AUDIT ============
AUDIT_ENABLED=True
AUDIT_RETENTION_DAYS=90

# ============ CORS ============
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://192.168.88.1

# ============ RAILWAY DEPLOYMENT ============
RAILWAY_ENVIRONMENT=production
